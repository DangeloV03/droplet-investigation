# Copy to scripts/slurm.env and edit for your Della account:
#   cp scripts/slurm.env.example scripts/slurm.env
#
# scripts/slurm.env is gitignored.

PARTITION=cpu
CPUS_PER_TASK=1
MEM=8G
# Integer minutes (48 hours). Passed to sbatch --time on the CLI (not in a #SBATCH line).
TIME_MINUTES=2880

# Optional — uncomment if sbatch requires it:
# ACCOUNT=your_account

REPORT_DIR=/home/vd7294/slurm_reports
PROJECT_ROOT=/scratch/gpfs/WJACOBS/vd7294/droplet-investigation

JOB_NAME_PREFIX=droplet_sim
